# ===== API Keys =====

# Helius API Key (https://dashboard.helius.dev/)
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API Key (https://birdeye.so/developer)
BIRDEYE_API_KEY=your_birdeye_api_key_here

# X (Twitter) Bearer Token
X_BEARER_TOKEN=your_x_bearer_token_here

# ===== Webshare Proxy (解决腾讯云 IP 被 X 封锁) =====
# 模式选择: "direct"（推荐，用统一入口轮换IP）或 "list"（拉取代理列表）
WEBSHARE_PROXY_MODE=direct

# direct 模式: 在 Webshare Dashboard -> Proxy -> Proxy Credentials 获取
WEBSHARE_PROXY_USER=your_webshare_username
WEBSHARE_PROXY_PASS=your_webshare_password

# ===== Webhook 推送配置 =====
# 接收服务器的 webhook URL
# 格式: http://服务器IP:3003/webhook/add-token
WEBHOOK_URL=http://your-server-ip:3003/webhook/add-token

# 触发条件（AND 关系，全部满足才发送）
WEBHOOK_MIN_FDV=100000
WEBHOOK_MIN_LP=10000
WEBHOOK_MIN_X=500

# ===== Server Config =====
PORT=3000

# ===== Filter Thresholds =====
# Auto-exit: age > 48H
MAX_AGE_HOURS=48

# Auto-exit: age > 1H AND FDV < 50000
MIN_FDV_AFTER_1H=50000

# Auto-exit: age > 1H AND LP < 10000
MIN_LP_AFTER_1H=10000

# Auto-exit: LP < 2000 (always)
MIN_LP_ABSOLUTE=2000
